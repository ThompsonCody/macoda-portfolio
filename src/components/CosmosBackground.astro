<div class="cosmos" aria-hidden="true">
  <canvas id="starfield"></canvas>
  <div class="cosmos__grain"></div>
</div>

<script>
  class Star {
    x: number;
    y: number;
    radius: number;
    baseAlpha: number;
    twinkleSpeed: number;
    phase: number;
    driftX: number;
    driftY: number;
    glow: boolean;
    color: string;

    constructor(private canvas: HTMLCanvasElement, private bright = false) {
      this.x = 0;
      this.y = 0;
      this.radius = 0;
      this.baseAlpha = 0;
      this.twinkleSpeed = 0;
      this.phase = 0;
      this.driftX = 0;
      this.driftY = 0;
      this.glow = false;
      this.color = "255,255,255";
      this.reset();
    }

    reset() {
      this.x = Math.random() * this.canvas.width;
      this.y = Math.random() * this.canvas.height;

      if (this.bright) {
        this.radius = Math.random() * 1.8 + 0.7;
        this.baseAlpha = Math.random() * 0.3 + 0.35;
        this.glow = true;
      } else {
        this.radius =
          Math.random() < 0.82
            ? Math.random() * 0.7 + 0.08
            : Math.random() * 1.2 + 0.18;
        this.baseAlpha = Math.random() * 0.45 + 0.12;
        this.glow = Math.random() < 0.12;
      }

      this.twinkleSpeed = Math.random() * 0.028 + 0.006;
      this.phase = Math.random() * Math.PI * 2;

      this.driftX = (Math.random() - 0.5) * 0.03;
      this.driftY = (Math.random() - 0.5) * 0.03;

      const warm = Math.random();
      if (warm < 0.08) {
        this.color = "255,236,210";
      } else if (warm < 0.12) {
        this.color = "220,235,255";
      } else {
        this.color = "255,255,255";
      }
    }

    update() {
      this.phase += this.twinkleSpeed;
      this.x += this.driftX;
      this.y += this.driftY;

      if (this.x < -4) this.x = this.canvas.width + 4;
      if (this.x > this.canvas.width + 4) this.x = -4;
      if (this.y < -4) this.y = this.canvas.height + 4;
      if (this.y > this.canvas.height + 4) this.y = -4;
    }

    draw(ctx: CanvasRenderingContext2D) {
      const pulse = Math.sin(this.phase);
      const shimmer = Math.sin(this.phase * 2.3 + this.x * 0.01) * 0.08;
      const alpha = Math.max(this.baseAlpha + pulse * 0.16 + shimmer, 0.03);

      if (this.glow) {
        const glowRadius = this.radius * (this.bright ? 7 : 4.5);
        const gradient = ctx.createRadialGradient(
          this.x,
          this.y,
          0,
          this.x,
          this.y,
          glowRadius
        );

        gradient.addColorStop(0, `rgba(${this.color}, ${alpha * 0.22})`);
        gradient.addColorStop(0.35, `rgba(${this.color}, ${alpha * 0.10})`);
        gradient.addColorStop(1, `rgba(${this.color}, 0)`);

        ctx.beginPath();
        ctx.fillStyle = gradient;
        ctx.arc(this.x, this.y, glowRadius, 0, Math.PI * 2);
        ctx.fill();
      }

      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${this.color}, ${alpha})`;
      ctx.fill();

      if (this.bright && alpha > 0.45) {
        ctx.beginPath();
        ctx.moveTo(this.x - this.radius * 2.2, this.y);
        ctx.lineTo(this.x + this.radius * 2.2, this.y);
        ctx.moveTo(this.x, this.y - this.radius * 2.2);
        ctx.lineTo(this.x, this.y + this.radius * 2.2);
        ctx.strokeStyle = `rgba(${this.color}, ${alpha * 0.22})`;
        ctx.lineWidth = 0.6;
        ctx.stroke();
      }
    }
  }

  class DustParticle {
    x: number;
    y: number;
    radius: number;
    alpha: number;
    driftX: number;
    driftY: number;
    phase: number;
    pulseSpeed: number;
    color: string;

    constructor(private canvas: HTMLCanvasElement) {
      this.x = 0;
      this.y = 0;
      this.radius = 0;
      this.alpha = 0;
      this.driftX = 0;
      this.driftY = 0;
      this.phase = 0;
      this.pulseSpeed = 0;
      this.color = "255,255,255";
      this.reset();
    }

    reset() {
      this.x = Math.random() * this.canvas.width;
      this.y = Math.random() * this.canvas.height;
      this.radius = Math.random() * 10 + 4;
      this.alpha = Math.random() * 0.035 + 0.015;
      this.driftX = (Math.random() - 0.5) * 0.02;
      this.driftY = (Math.random() - 0.5) * 0.02;
      this.phase = Math.random() * Math.PI * 2;
      this.pulseSpeed = Math.random() * 0.01 + 0.002;

      const tone = Math.random();
      if (tone < 0.2) {
        this.color = "255,220,190";
      } else if (tone < 0.35) {
        this.color = "210,225,255";
      } else {
        this.color = "255,245,235";
      }
    }

    update() {
      this.phase += this.pulseSpeed;
      this.x += this.driftX;
      this.y += this.driftY;

      if (this.x < -20) this.x = this.canvas.width + 20;
      if (this.x > this.canvas.width + 20) this.x = -20;
      if (this.y < -20) this.y = this.canvas.height + 20;
      if (this.y > this.canvas.height + 20) this.y = -20;
    }

    draw(ctx: CanvasRenderingContext2D) {
      const alpha = this.alpha + Math.sin(this.phase) * 0.01;
      const gradient = ctx.createRadialGradient(
        this.x,
        this.y,
        0,
        this.x,
        this.y,
        this.radius
      );

      gradient.addColorStop(0, `rgba(${this.color}, ${Math.max(alpha, 0.008)})`);
      gradient.addColorStop(0.45, `rgba(${this.color}, ${Math.max(alpha * 0.5, 0.004)})`);
      gradient.addColorStop(1, `rgba(${this.color}, 0)`);

      ctx.beginPath();
      ctx.fillStyle = gradient;
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  const canvas = document.getElementById("starfield") as HTMLCanvasElement | null;
  const shell = document.querySelector(".site-shell") as HTMLElement | null;
  const ctx = canvas?.getContext("2d");

  if (canvas && shell && ctx) {
    let stars: Star[] = [];
    let dust: DustParticle[] = [];

    const STAR_COUNT = 720;
    const BRIGHT_STAR_COUNT = 85;
    const DUST_COUNT = 36;

    function resize() {
      canvas.width = shell.scrollWidth;
      canvas.height = shell.scrollHeight;
    }

    function buildScene() {
      stars = [];
      dust = [];

      for (let i = 0; i < STAR_COUNT; i++) {
        stars.push(new Star(canvas, false));
      }

      for (let i = 0; i < BRIGHT_STAR_COUNT; i++) {
        stars.push(new Star(canvas, true));
      }

      for (let i = 0; i < DUST_COUNT; i++) {
        dust.push(new DustParticle(canvas));
      }
    }

    function drawBackground() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      for (const particle of dust) {
        particle.update();
        particle.draw(ctx);
      }

      for (const star of stars) {
        star.update();
        star.draw(ctx);
      }

      requestAnimationFrame(drawBackground);
    }

    function rebuild() {
      resize();
      buildScene();
    }

    rebuild();
    drawBackground();

    const handleResize = () => rebuild();
    window.addEventListener("resize", handleResize);

    const observer = new ResizeObserver(() => {
      rebuild();
    });

    observer.observe(shell);
  }
</script>

<style>
  .cosmos {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background:
      radial-gradient(circle at 20% 10%, rgba(50, 60, 120, 0.16), transparent 25%),
      radial-gradient(circle at 80% 40%, rgba(255, 140, 0, 0.08), transparent 22%),
      radial-gradient(circle at 40% 80%, rgba(90, 60, 120, 0.14), transparent 22%),
      radial-gradient(circle at 60% 60%, rgba(255,255,255,0.03), transparent 40%),
      #0b0908;
  }

  #starfield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.96;
  }

  .cosmos__grain {
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 0.5px, transparent 0.5px);
    background-size: 6px 6px;
    mix-blend-mode: soft-light;
  }
</style>