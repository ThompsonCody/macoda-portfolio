<div class="cosmos" aria-hidden="true">
  <canvas id="starfield"></canvas>
  <div class="cosmos__grain"></div>
</div>

<script>
  class Star {
    x: number;
    y: number;
    radius: number;
    baseAlpha: number;
    twinkleSpeed: number;
    phase: number;

    constructor(private canvas: HTMLCanvasElement) {
      this.x = 0;
      this.y = 0;
      this.radius = 0;
      this.baseAlpha = 0;
      this.twinkleSpeed = 0;
      this.phase = 0;
      this.reset();
    }

    reset() {
      this.x = Math.random() * this.canvas.width;
      this.y = Math.random() * this.canvas.height;
      this.radius = Math.random() * 1.2 + 0.15;
      this.baseAlpha = Math.random() * 0.45 + 0.08;
      this.twinkleSpeed = Math.random() * 0.02 + 0.003;
      this.phase = Math.random() * Math.PI * 2;
    }

    draw(ctx: CanvasRenderingContext2D) {
      this.phase += this.twinkleSpeed;
      const alpha = this.baseAlpha + Math.sin(this.phase) * 0.12;

      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${Math.max(alpha, 0.03)})`;
      ctx.fill();
    }
  }

  const canvas = document.getElementById("starfield") as HTMLCanvasElement | null;
  const shell = document.querySelector(".site-shell") as HTMLElement | null;
  const ctx = canvas?.getContext("2d");

  if (canvas && shell && ctx) {
    let stars: Star[] = [];
    const STAR_COUNT = 320;

    function resize() {
      const width = shell.scrollWidth;
      const height = shell.scrollHeight;

      canvas.width = width;
      canvas.height = height;
    }

    function buildStars() {
      stars = [];
      for (let i = 0; i < STAR_COUNT; i++) {
        stars.push(new Star(canvas));
      }
    }

    function drawBackground() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach((star) => star.draw(ctx));
      requestAnimationFrame(drawBackground);
    }

    function rebuild() {
      resize();
      buildStars();
    }

    rebuild();
    drawBackground();

    window.addEventListener("resize", rebuild);

    const observer = new ResizeObserver(() => {
      rebuild();
    });

    observer.observe(shell);
  }
</script>

<style>
  .cosmos {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 18% 14%, rgba(38, 34, 52, 0.08) 0%, transparent 24%),
      radial-gradient(ellipse at 74% 36%, rgba(58, 34, 20, 0.04) 0%, transparent 20%),
      radial-gradient(ellipse at 50% 70%, rgba(32, 26, 40, 0.05) 0%, transparent 24%),
      #040303;
  }

  #starfield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.85;
  }

  .cosmos__grain {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 0.5px, transparent 0.5px);
    background-size: 6px 6px;
    mix-blend-mode: soft-light;
  }
</style>