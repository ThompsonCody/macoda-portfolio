---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SelectedWork from "../components/SelectedWork.astro";
import QuoteSection from "../components/QuoteSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";
import { getCreations } from "../lib/sanity";

const creations = await getCreations();
---

<BaseLayout
  title="MacOda"
  description="Art, design, branding, and symbolic visual identity through illustration and storytelling."
>
<!-- <BaseLayout
  title={`${creation.title} | Macoda`}
  description={creation.seoDescription ?? creation.excerpt}
> -->
  <main>
    <Hero />
    <SelectedWork creations={creations} />
    <QuoteSection />
    <AboutSection />
    <ContactSection />
    <Footer />
  </main>
</BaseLayout>